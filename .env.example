# Copier en .env et adapter les valeurs
# Ne jamais commiter .env

# URL de l'API du module Collaboratif (pivot-collaboratif-core), pour le dev standalone
# de ce repo. En production, ce module est lazy-loaded dans le shell pivot-ui — l'URL
# effective vient alors de nginx (voir pivot-docs/docs/architecture/platform-overview.md).
PIVOT_COLLABORATIF_API_URL=http://localhost:8083
