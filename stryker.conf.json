{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts",
    "related": false
  },
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "concurrency": 4,
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.config.ts",
    "!src/main.ts",
    "!src/test-setup.ts",
    "!src/**/environment*.ts",
    "projects/collaboratif-ui/src/**/*.ts",
    "!projects/collaboratif-ui/src/**/*.spec.ts",
    "!projects/collaboratif-ui/src/public-api.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "tempDirName": ".stryker-tmp",
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  }
}
